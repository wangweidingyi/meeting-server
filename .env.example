MEETING_UDP_HOST=127.0.0.1
MEETING_UDP_PORT=6000
MEETING_HTTP_HOST=127.0.0.1
MEETING_HTTP_PORT=8090
MEETING_DATABASE_URL=

# Local desktop integration can run against the built-in broker.
MEETING_MQTT_EMBEDDED=true
MEETING_MQTT_LISTEN_HOST=127.0.0.1
MEETING_MQTT_LISTEN_PORT=1883

# Optional external broker target. Leave empty to let the runtime client use the
# embedded broker when MEETING_MQTT_EMBEDDED=true.
MEETING_MQTT_BROKER=
MEETING_MQTT_CLIENT_ID=meeting-server
MEETING_MQTT_USERNAME=
MEETING_MQTT_PASSWORD=

# AI provider selection
MEETING_STT_PROVIDER=stub
MEETING_STT_BASE_URL=
MEETING_STT_API_KEY=
MEETING_STT_MODEL=

MEETING_LLM_PROVIDER=stub
MEETING_LLM_BASE_URL=
MEETING_LLM_API_KEY=
MEETING_LLM_MODEL=

# TTS is not yet wired into the meeting transport flow, but the provider seam is ready.
MEETING_TTS_PROVIDER=stub
MEETING_TTS_BASE_URL=
MEETING_TTS_API_KEY=
MEETING_TTS_MODEL=
MEETING_TTS_VOICE=
